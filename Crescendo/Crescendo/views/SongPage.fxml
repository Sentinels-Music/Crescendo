<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>
<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.CrescendoController"
            prefWidth="933"
            prefHeight="695"
            style="-fx-background-color: #F6F1E8;">
    <AnchorPane prefWidth="242"
                AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                style="-fx-background-color: #171713; -fx-background-radius: 0 10 10 0;">
        <Label text="Crescendo"
               layoutX="20"
               layoutY="38"
               textFill="#F4D66A"
               style="-fx-font-size: 30px; -fx-font-weight: bold;" />
        <VBox layoutX="20"
              layoutY="106"
              spacing="16"
              prefWidth="202">
            <Button text="Home" onAction="#goHome"
                    prefWidth="202"
                    prefHeight="46"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EEE6D8;
                           -fx-font-size: 15px;
                           -fx-padding: 0 0 0 18;" />
            <Button text="Discover" onAction="#goDiscover"
                    prefWidth="202"
                    prefHeight="50"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: #E2AE3F;
                           -fx-text-fill: #11110E;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 14;
                           -fx-padding: 0 0 0 18;" />
            <Button text="Listen Later" onAction="#goListenLater"
                    prefWidth="202"
                    prefHeight="46"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EEE6D8;
                           -fx-font-size: 15px;
                           -fx-padding: 0 0 0 18;" />
        </VBox>
        <HBox spacing="12"
              alignment="CENTER_LEFT"
              prefWidth="202"
              prefHeight="62"
              AnchorPane.leftAnchor="20"
              AnchorPane.bottomAnchor="24"
              onMouseClicked="#goProfile"
              style="-fx-background-color: #22211C;
                     -fx-background-radius: 18;
                     -fx-padding: 10 12 10 12;
                     -fx-cursor: hand;">
            <Button prefWidth="42"
                    prefHeight="42"
                    onAction="#goProfile"
                    style="-fx-background-color: transparent;
                           -fx-padding: 0;
                           -fx-background-radius: 21;
                           -fx-border-color: transparent;">
                <graphic>
                    <Circle radius="21"
                            fill="#8B8B83" />
                </graphic>
            </Button>
            <VBox spacing="2">
                <Label text="mustafa"
                       textFill="#F6F1E8"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                <Label text="Verified"
                       textFill="#E2AE3F"
                       style="-fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>
        </HBox>
    </AnchorPane>
    <HBox alignment="CENTER_LEFT"
          spacing="10"
          prefWidth="310"
          prefHeight="42"
          AnchorPane.topAnchor="32"
          AnchorPane.rightAnchor="72"
          style="-fx-background-color: white;
                 -fx-background-radius: 18;
                 -fx-border-color: #E4D8C2;
                 -fx-border-radius: 18;
                 -fx-padding: 0 14 0 14;">
        <SVGPath content="M9.5 3 C5.9 3 3 5.9 3 9.5 C3 13.1 5.9 16 9.5 16 C11 16 12.4 15.5 13.5 14.7 L17.4 18.6 C17.8 19 18.4 19 18.8 18.6 C19.2 18.2 19.2 17.6 18.8 17.2 L14.9 13.3 C15.6 12.2 16 10.9 16 9.5 C16 5.9 13.1 3 9.5 3 Z M9.5 5 C12 5 14 7 14 9.5 C14 12 12 14 9.5 14 C7 14 5 12 5 9.5 C5 7 7 5 9.5 5 Z"
                 fill="#737373"
                 scaleX="0.9"
                 scaleY="0.9" />
        <TextField promptText="Search artists, albums and songs..."
                   prefWidth="240"
                   prefHeight="38"
                   style="-fx-background-color: transparent;
                          -fx-border-color: transparent;
                          -fx-font-size: 14px;
                          -fx-prompt-text-fill: #8A8A8A;" />
    </HBox>
    <Button text="×"
            prefWidth="32"
            prefHeight="32"
            AnchorPane.topAnchor="12"
            AnchorPane.rightAnchor="14"
            onAction="#closeWindow"
            style="-fx-background-color: #D94141;
                   -fx-text-fill: white;
                   -fx-font-size: 18px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 10;
                   -fx-padding: 0;" />

    <VBox spacing="18"
          AnchorPane.topAnchor="90"
          AnchorPane.leftAnchor="282"
          AnchorPane.rightAnchor="40">
        <HBox spacing="20"
              alignment="CENTER_LEFT">
            <StackPane prefWidth="92"
                       prefHeight="92"
                       style="-fx-background-color: #1E1E19; -fx-background-radius: 12;">
                <Label text="♪"
                       textFill="#E2AE3F"
                       style="-fx-font-size: 30px;" />
            </StackPane>
            <VBox spacing="4">
                <Label text="SONG"
                       textFill="#B0A891"
                       style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                <Label text="Let It Happen"
                       textFill="#171713"
                       style="-fx-font-size: 30px; -fx-font-weight: bold;" />
                <Label text="Tame Impala · Currents · 7:47"
                       textFill="#8A8A8A"
                       style="-fx-font-size: 14px;" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <VBox spacing="2"
                  alignment="CENTER_RIGHT">
                <HBox spacing="2"
                      alignment="BOTTOM_RIGHT">
                    <Label text="4.7"
                           textFill="#171713"
                           style="-fx-font-size: 34px; -fx-font-weight: bold;" />
                    <Label text="/5"
                           textFill="#8A8A8A"
                           style="-fx-font-size: 14px; -fx-padding: 0 0 8 0;" />
                </HBox>
                <Label text="★★★★★"
                       textFill="#E2AE3F"
                       style="-fx-font-size: 14px;" />
                <Label text="892 ratings"
                       textFill="#8A8A8A"
                       style="-fx-font-size: 12px;" />
            </VBox>
        </HBox>

        <Region prefHeight="1"
                style="-fx-background-color: #E4D8C2;" />

        <VBox spacing="8">
            <Label text="YOUR RATING"
                   textFill="#B0A891"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;" />
            <Label text="★★★★★"
                   textFill="#E2AE3F"
                   style="-fx-font-size: 22px;" />
            <HBox alignment="CENTER_LEFT">
                <Label text="Tap a star to rate — "
                       textFill="#8A8A8A"
                       style="-fx-font-size: 13px;" />
                <Label text="your rating saves instantly."
                       textFill="#C79A32"
                       style="-fx-font-size: 13px; -fx-font-weight: bold;" />
            </HBox>
        </VBox>

        <Region prefHeight="1"
                style="-fx-background-color: #E4D8C2;" />

        <VBox spacing="10">
            <Label text="APPEARS ON"
                   textFill="#B0A891"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;" />
            <HBox spacing="14"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: white;
                         -fx-background-radius: 14;
                         -fx-border-color: #E4D8C2;
                         -fx-border-radius: 14;
                         -fx-padding: 12 16 12 12;">
                <StackPane prefWidth="46"
                           prefHeight="46"
                           style="-fx-background-color: #1E1E19; -fx-background-radius: 10;">
                    <Label text="♪"
                           textFill="#E2AE3F"
                           style="-fx-font-size: 18px;" />
                </StackPane>
                <VBox spacing="2">
                    <Label text="Currents — Tame Impala"
                           textFill="#171713"
                           style="-fx-font-size: 15px; -fx-font-weight: bold;" />
                    <Label text="2015 · 13 tracks"
                           textFill="#8A8A8A"
                           style="-fx-font-size: 12px;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label text="›"
                       textFill="#B0A891"
                       style="-fx-font-size: 22px;" />
            </HBox>
        </VBox>

        <Region prefHeight="1"
                style="-fx-background-color: #E4D8C2;" />

        <VBox spacing="16">
            <Label text="REVIEWS"
                   textFill="#B0A891"
                   style="-fx-font-size: 12px; -fx-font-weight: bold;" />
            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT">
                    <Label text="elif_k "
                           textFill="#171713"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                    <Label text="rated this song"
                           textFill="#8A8A8A"
                           style="-fx-font-size: 14px;" />
                </HBox>
                <Label text="★★★★★"
                       textFill="#E2AE3F"
                       style="-fx-font-size: 13px;" />
                <Label text="“The drums alone are worth the 7 minutes. Best album opener of the decade.”"
                       textFill="#3A382F"
                       style="-fx-font-size: 13px;" />
                <Label text="2 hours ago · 31 likes"
                       textFill="#A0987F"
                       style="-fx-font-size: 12px;" />
            </VBox>
            <VBox spacing="4">
                <HBox alignment="CENTER_LEFT">
                    <Label text="can.polat "
                           textFill="#171713"
                           style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                    <Label text="rated this song"
                           textFill="#8A8A8A"
                           style="-fx-font-size: 14px;" />
                </HBox>
                <Label text="★★★★☆"
                       textFill="#E2AE3F"
                       style="-fx-font-size: 13px;" />
                <Label text="“Takes a couple listens to click, then it doesn't leave your head.”"
                       textFill="#3A382F"
                       style="-fx-font-size: 13px;" />
                <Label text="1 day ago · 14 likes"
                       textFill="#A0987F"
                       style="-fx-font-size: 12px;" />
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>
