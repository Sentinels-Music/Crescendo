<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="views.ProfileController"
            style="-fx-font-family: 'SansSerif';">

    <!-- ===== Sidebar ===== -->
    <left>
        <VBox style="-fx-background-color: #141414; -fx-padding: 30 20 30 20; -fx-spacing: 12; -fx-pref-width: 200;">
            <Label text="Crescendo"
                   style="-fx-font-size: 30px; -fx-font-weight: bold; -fx-text-fill: #D4AF37; -fx-padding: 0 0 16 0;" />
            <Button text="Home" onAction="#goHome"
                    style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: center-left; -fx-padding: 10 15 10 15; -fx-background-radius: 6; -fx-cursor: hand; -fx-max-width: infinity;" />
            <Button text="Discover" onAction="#goDiscover"
                    style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: center-left; -fx-padding: 10 15 10 15; -fx-background-radius: 6; -fx-cursor: hand; -fx-max-width: infinity;" />
            <Button text="Listen Later" onAction="#goListenLater"
                    style="-fx-background-color: transparent; -fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold; -fx-alignment: center-left; -fx-padding: 10 15 10 15; -fx-background-radius: 6; -fx-cursor: hand; -fx-max-width: infinity;" />

            <Region VBox.vgrow="ALWAYS" />

            <VBox style="-fx-background-color: #242424; -fx-padding: 12 15 12 15; -fx-background-radius: 8; -fx-spacing: 4;">
                <Label fx:id="sidebarName" text="mustafa"
                       style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold;" />
                <Label fx:id="sidebarVerified" text="Verified"
                       style="-fx-text-fill: #D4AF37; -fx-font-size: 12px; -fx-font-style: italic; -fx-font-weight: bold;" />
            </VBox>
        </VBox>
    </left>

    <!-- ===== Main content ===== -->
    <center>
        <VBox spacing="16"
              style="-fx-background-color: #FFFFFF; -fx-padding: 26 40 20 40;">

            <!-- top search bar -->
            <HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField promptText="Search artists, albums and songs..." prefWidth="320"
                           style="-fx-font-size: 14px; -fx-padding: 8 12 8 12; -fx-background-color: #FAFAFA; -fx-border-color: #DDDDDD; -fx-border-radius: 18; -fx-background-radius: 18;" />
            </HBox>

            <!-- header: avatar + name/bio + edit -->
            <HBox spacing="16" alignment="CENTER_LEFT">
                <Label fx:id="avatarLabel" text="M"
                       style="-fx-background-color: #D4AF37; -fx-background-radius: 60; -fx-min-width: 64; -fx-min-height: 64; -fx-max-width: 64; -fx-max-height: 64; -fx-alignment: center; -fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;" />

                <VBox spacing="4">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="usernameLabel" text="mustafa"
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
                        <Label fx:id="verifiedBadge" text="★ Verified"
                               style="-fx-text-fill: #D4AF37; -fx-font-size: 14px; -fx-font-weight: bold;" />
                    </HBox>
                    <Label fx:id="bioLabel" wrapText="true"
                           text="Yacht-rock to post-punk. Always one track away from a new favorite."
                           style="-fx-font-size: 14px; -fx-text-fill: #555555;" />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="editButton" text="Edit profile" onAction="#handleEditProfile"
                        style="-fx-background-color: #111111; -fx-text-fill: #FFFFFF; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 8 16 8 16; -fx-cursor: hand;" />
            </HBox>

            <!-- stats -->
            <HBox spacing="28" alignment="CENTER_LEFT">
                <VBox alignment="CENTER">
                    <Label fx:id="reviewsCount" text="0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
                    <Label text="REVIEWS"
                           style="-fx-font-size: 11px; -fx-text-fill: #888888;" />
                </VBox>
                <VBox alignment="CENTER">
                    <Label fx:id="followingCount" text="0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
                    <Label text="FOLLOWING"
                           style="-fx-font-size: 11px; -fx-text-fill: #888888;" />
                </VBox>
                <VBox alignment="CENTER">
                    <Label fx:id="followersCount" text="0"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
                    <Label text="FOLLOWERS"
                           style="-fx-font-size: 11px; -fx-text-fill: #888888;" />
                </VBox>
            </HBox>

            <Separator />

            <!-- two columns: reviews + following -->
            <HBox spacing="40" VBox.vgrow="ALWAYS">

                <VBox spacing="12" HBox.hgrow="ALWAYS" prefWidth="360">
                    <Label text="MY REVIEWS"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #888888;" />
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox fx:id="reviewsBox" spacing="14" />
                    </ScrollPane>
                </VBox>

                <VBox spacing="12" HBox.hgrow="ALWAYS" prefWidth="320">
                    <Label text="FOLLOWING"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #888888;" />
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                        <VBox fx:id="followingBox" spacing="14" />
                    </ScrollPane>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
