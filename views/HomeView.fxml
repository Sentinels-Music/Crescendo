<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.SVGPath?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="CrescendoController"
            prefWidth="933"
            prefHeight="695"
            style="-fx-background-color: #F6F1E8;">

    <AnchorPane prefWidth="242"
                AnchorPane.topAnchor="0"
                AnchorPane.bottomAnchor="0"
                AnchorPane.leftAnchor="0"
                style="-fx-background-color: #171713; -fx-background-radius: 0 10 10 0;">

        <Label text="Crescendo"
               layoutX="20"
               layoutY="38"
               textFill="#F4D66A"
               style="-fx-font-size: 30px; -fx-font-weight: bold;" />

        <VBox layoutX="20"
              layoutY="106"
              spacing="16"
              prefWidth="202">

            <Button text="Home"
                    prefWidth="202"
                    prefHeight="50"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: #E2AE3F;
                           -fx-text-fill: #11110E;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 14;
                           -fx-padding: 0 0 0 18;" />

            <Button text="Discover"
                    prefWidth="202"
                    prefHeight="46"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EEE6D8;
                           -fx-font-size: 15px;
                           -fx-padding: 0 0 0 18;" />

            <Button text="Listen Later"
                    prefWidth="202"
                    prefHeight="46"
                    alignment="CENTER_LEFT"
                    style="-fx-background-color: transparent;
                           -fx-text-fill: #EEE6D8;
                           -fx-font-size: 15px;
                           -fx-padding: 0 0 0 18;" />

        </VBox>

        <HBox spacing="12"
              alignment="CENTER_LEFT"
              prefWidth="202"
              prefHeight="62"
              AnchorPane.leftAnchor="20"
              AnchorPane.bottomAnchor="24"
              style="-fx-background-color: #22211C;
                     -fx-background-radius: 18;
                     -fx-padding: 10 12 10 12;">

            <Button prefWidth="42"
                    prefHeight="42"
                    style="-fx-background-color: transparent;
                           -fx-padding: 0;
                           -fx-background-radius: 21;
                           -fx-border-color: transparent;">
                <graphic>
                    <Circle radius="21"
                            fill="#8B8B83" />
                </graphic>
            </Button>

            <VBox spacing="2">
                <Label text="Example User"
                       textFill="#F6F1E8"
                       style="-fx-font-size: 14px; -fx-font-weight: bold;" />

                <Label text="Verified"
                       textFill="#E2AE3F"
                       style="-fx-font-size: 12px; -fx-font-weight: bold;" />
            </VBox>

        </HBox>

    </AnchorPane>

    <HBox alignment="CENTER_LEFT"
          spacing="10"
          prefWidth="310"
          prefHeight="42"
          AnchorPane.topAnchor="32"
          AnchorPane.rightAnchor="72"
          style="-fx-background-color: white;
                 -fx-background-radius: 18;
                 -fx-border-color: #E4D8C2;
                 -fx-border-radius: 18;
                 -fx-padding: 0 14 0 14;">

        <SVGPath content="M9.5 3 C5.9 3 3 5.9 3 9.5 C3 13.1 5.9 16 9.5 16 C11 16 12.4 15.5 13.5 14.7 L17.4 18.6 C17.8 19 18.4 19 18.8 18.6 C19.2 18.2 19.2 17.6 18.8 17.2 L14.9 13.3 C15.6 12.2 16 10.9 16 9.5 C16 5.9 13.1 3 9.5 3 Z M9.5 5 C12 5 14 7 14 9.5 C14 12 12 14 9.5 14 C7 14 5 12 5 9.5 C5 7 7 5 9.5 5 Z"
                 fill="#737373"
                 scaleX="0.9"
                 scaleY="0.9" />

        <TextField promptText="Search artists, albums and songs..."
                   prefWidth="240"
                   prefHeight="38"
                   style="-fx-background-color: transparent;
                          -fx-border-color: transparent;
                          -fx-font-size: 14px;
                          -fx-prompt-text-fill: #8A8A8A;" />

    </HBox>

    <Button text="×"
            prefWidth="32"
            prefHeight="32"
            AnchorPane.topAnchor="12"
            AnchorPane.rightAnchor="14"
            onAction="#closeWindow"
            style="-fx-background-color: #D94141;
                   -fx-text-fill: white;
                   -fx-font-size: 18px;
                   -fx-font-weight: bold;
                   -fx-background-radius: 10;
                   -fx-padding: 0;" />

</AnchorPane>