<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="views.LoginController"
           style="-fx-background-color: #F2F2F2; -fx-font-family: 'SansSerif';">

    <VBox fx:id="card" maxWidth="360" maxHeight="360"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 10; -fx-padding: 30 40 30 40; -fx-spacing: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 14, 0, 0, 4);">

        <HBox spacing="16">
            <Label text="Login"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #000000;" />
            <Button text="Register" onAction="#goToRegister"
                    style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #AAAAAA; -fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0;" />
        </HBox>

        <Label text="Username"
               style="-fx-font-size: 13px; -fx-text-fill: #666666;" />
        <TextField fx:id="usernameField" promptText="Username"
                   style="-fx-font-size: 15px; -fx-padding: 8; -fx-background-color: #FAFAFA; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-radius: 5;" />

        <Label text="Password"
               style="-fx-font-size: 13px; -fx-text-fill: #666666;" />
        <PasswordField fx:id="passwordField" promptText="Password"
                       style="-fx-font-size: 15px; -fx-padding: 8; -fx-background-color: #FAFAFA; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-radius: 5;" />

        <Button text="Log in" onAction="#handleLogin"
                style="-fx-background-color: #111111; -fx-text-fill: #FFFFFF; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 6; -fx-padding: 10 20 10 20; -fx-cursor: hand; -fx-max-width: infinity;" />

        <Button text="Forgot Password?" onAction="#handleForgotPassword"
                style="-fx-background-color: transparent; -fx-text-fill: #5B5BD6; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 0;" />

        <Label fx:id="messageLabel" wrapText="true"
               style="-fx-text-fill: #C0392B; -fx-font-size: 13px;" />
    </VBox>
</StackPane>
